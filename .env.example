# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# GitHub Configuration for Admin Editing
# GITHUB_REPO: Your repository in format: username/repo
GITHUB_REPO="your-username/your-repo"

# GITHUB_TOKEN: Personal access token with repo/contents scope (create at github.com/settings/tokens)
# Scopes needed: repo (full control of private repositories)
# Note: Keep this secret! Use it only on trusted machines.
GITHUB_TOKEN="github_pat_xxxxxxxxxx"

